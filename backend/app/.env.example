# ──────────────────────────────────────────────────────────────────────────────
# Winlytics — Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env with real credentials.
#
# ⚠️  SECURITY NOTICE:
#     If you are reading this after a credentials leak, rotate ALL secrets below:
#       - Regenerate MONGO_URI credentials in MongoDB Atlas
#       - Regenerate REDIS_URL password in Upstash / Redis Cloud
#       - Generate a new JWT_SECRET: `openssl rand -hex 32`
#       - Regenerate your CricAPI key at https://www.cricapi.com/
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Winlytics

# Upstash or any Redis-compatible connection string
REDIS_URL=redis://default:<password>@<host>:<port>

# CricAPI key — https://www.cricapi.com/
CRICAPI_KEY=your-cricapi-key-here

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example for production: ALLOWED_ORIGINS=https://winlytics.vercel.app
# Example for local dev:  ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
